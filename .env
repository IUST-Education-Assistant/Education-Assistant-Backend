# --- API ---
API_PORT=8000

# --- Postgres (docker-compose will create these) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=education_db
POSTGRES_PORT=5432
# DATABASE_URL=

# --- Auth / JWT ---
# Set a long random string in production
SECRET_KEY=change_this
ACCESS_TOKEN_EXPIRE_MINUTES=2

# --- LLM (Groq) ---
# GROQ_API_KEY=
GROQ_LLM_MODEL=qwen/qwen3-32b

# --- Embeddings ---
# If you mount a local model folder to /app/embedding_model, set:
# EMBEDDING_MODEL_PATH=/app/embedding_model
# Otherwise set a HuggingFace model id:
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- SMTP (OTP email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=aminnoormahmoodi2@gmail.com
SMTP_PASSWORD=szprvtmcsgnsatlq
SMTP_FROM=aminnoormahmoodi2@gmail.com
